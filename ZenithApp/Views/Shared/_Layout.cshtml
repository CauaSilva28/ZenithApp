@{
    var usuarioNome = Context.Session.GetString("UsuarioNome");
    var usuarioTipo = Context.Session.GetString("UsuarioTipo");
    var logado = usuarioNome != null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zenith</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ZenithApp.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar-custom">
            <div class="nav-logo">
                <div class="nav-logo-background">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <a class="zenith" asp-area="" asp-controller="Home" asp-action="Index">Zenith</a>
            </div>


            </div>
            <ul class="nav-links">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Conteudo">Conteúdos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Treino">Treinos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Performance">Performance</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Sobre">Sobre Nós</a>
                </li>
            </ul>

            <div class="nav-buttons">
            
            @if (logado) {
                <div class="nav-user">
                    <a asp-controller="Home" asp-action="Atleta" class="btn btn-green">@usuarioNome  <i class="bi bi-person-circle"></i></a>
                    <a href="#" class="btn btn-outline" onclick="document.getElementById('modalSair').style.display='flex'; return false;"> Sair <i class="bi bi-box-arrow-right"></i></a>
                </div>

                <div id="modalSair" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:9999; align-items:center; justify-content:center;">
                    <div id="modalContent" style="">
                        <i class="bi bi-box-arrow-right" style="font-size:2rem; color:#e74c3c;"></i>
                        <h5 style="margin:.75rem 0 .5rem;">Deseja sair?</h5>
                        <p style="color:#666; font-size:.9rem; margin-bottom:1.5rem;">Você será desconectado da sua conta.</p>
                        <div style="display:flex; gap:.75rem; justify-content:center;">
                            <button class="btn btn-green"
                                    onclick="document.getElementById('modalSair').style.display='none'">
                                Continuar navegando
                            </button>
                            <a asp-controller="Auth" asp-action="Logout">
                                <button class="btn btn-red">
                                    Sair da conta
                                </button>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline">Entrar</a>
                <a asp-controller="Auth" asp-action="Cadastro" class="btn btn-green">Começar agora</a>
            }
            </div>
        </nav>
    </header>

    <main role="main" class="p-0">
        @RenderBody()
    </main>

    <footer>
        <div class="col1">
            <div class="nav-logo">
                <div class="nav-logo-background">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <a class="zenith" asp-area="" asp-controller="Home" asp-action="Index">Zenith</a>
            </div>
            <p>Texto</p>
            <div class="icones-redes">
                <i class="bi bi-instagram"></i>
            </div>
            <p>copyright Zenith 2026</p>
        </div>

        <div class="col2">
            <h4>Suporte</h4>
            <a href="">Central de ajuda</a>
            <a href="">Fale conosco</a>
            <a href="">Termos de uso</a>
        </div>

        <div class="col3">
            <h4>Institucional</h4>
            <a href="">Sobre a Zenith</a>
            <a href="">Contato</a>
            <a href="">Carreiras</a>
        </div>
    </footer>
</body>

<script>
    document.getElementById('modalSair')?.addEventListener('click', function (e) {
        if (e.target === this) this.style.display = 'none';
    });
</script>

</html>
