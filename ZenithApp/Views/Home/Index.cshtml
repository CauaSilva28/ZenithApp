@{
    Layout = "_Layout";
    var logado = Context.Session.GetString("UsuarioNome") != null;
    var tipo = Context.Session.GetString("UsuarioTipo");
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<section id="home-hero">
    <div class="overlay"></div>
    <div class="hero-content">
        <div class="hero-left">
            <br><br>
            <h3>ALTO RENDIMENTO</h3>
            <h1>Seja sua<br>melhor versão. <br>Todo dia.</h1>
            <p>Conteúdo, treinos e estratégias para atletas que buscam excelência e treinadores que constroem resultados extraordinários.</p>
            @if (!logado) {
                <div class="hero-btns">
                    <a href="#"><button class="hero-btn1">Sou atleta <i class="bi bi-arrow-right"></i></button></a>
                    <a href="#"><button class="hero-btn2">Sou treinador <i class="bi bi-arrow-right"></i></button></a>
                </div>
            }
            
            else {
                <div class="hero-btns">
                    <a asp-controller="@(tipo == "Treinador" ? "Treinador" : "Atleta")" asp-action="Index">
                        <button class="hero-btn1">Minha área <i class="bi bi-arrow-right"></i></button>
                    </a>
                </div>
            }
        </div>

        <div class="hero-right">
            <img src="~/img/heroImg.png" alt="Quadrados verdes">
        </div>
    </div>

    <div class="hero-topicos">
        <div class="topico">
            <i class="bi bi-arrow-right"></i>
            <span>Conteúdo exclusivo de alto nível</span>
        </div>

        <div class="topico">
            <i class="bi bi-arrow-right"></i>
            <span>Planos e treinos personalizados</span>
        </div>

        <div class="topico">
            <i class="bi bi-arrow-right"></i>
            <span>Evolução baseada em dados reais</span>
        </div>
    </div>
</section>

<section id="sobre">
    <div class="sobre-img">
        <img src="~/img/imgSobre.png" alt="Imagem de atleta" />
    </div>

    <div class="sobre-conteudo">
        <h3>SOBRE</h3>
        <h2>Eleve seus Treinos</h2>
        <p>Monitore Sua dieta e seus treinos com apoio de seus treinadores. Monitore Sua dieta e seus treinos com apoio de seus treinadores.</p>
