@{
    Layout = "_Layout";
    var logado = Context.Session.GetString("UsuarioNome") != null;
    var tipo = Context.Session.GetString("UsuarioTipo");
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/homeMobile.css" asp-append-version="true" />
}

<section id="home-hero">
    <div class="overlay"></div>
    <div class="hero-content">
        <div class="hero-left">
            <br><br>
            <h3>ALTO RENDIMENTO</h3>
            <h1>Seja sua<br>melhor versão. <br>Todo dia.</h1>
            <p>Conteúdo, treinos e estratégias para atletas que buscam excelência e treinadores que constroem resultados extraordinários.</p>
            @if (!logado) {
                <div class="hero-btns">
                    <a a asp-controller="Auth" asp-action="Cadastro" asp-route-tipoUsuario="Atleta"><button class="hero-btn1">Sou atleta <i class="bi bi-arrow-right"></i></button></a>
                    <a a asp-controller="Auth" asp-action="Cadastro" asp-route-tipoUsuario="Treinador"><button class="hero-btn2">Sou treinador <i class="bi bi-arrow-right"></i></button></a>
                </div>
            }
            else {
                <div class="hero-btns">
                    <a asp-controller="@(tipo == "Treinador" ? "Treinador" : "Atleta")" asp-action="Index">
                        <button class="hero-btn1">Área do @tipo <i class="bi bi-arrow-right"></i></button>
                    </a>
                </div>
            }
        </div>

        <div class="hero-right">
            <img src="~/img/heroImg.png" alt="Quadrados verdes">
        </div>
    </div>

    <div class="hero-topicos">
        <div class="topico">
            <i class="bi bi-graph-up-arrow"></i>
            <span>Conteúdo exclusivo de alto nível</span>
        </div>

        <div class="topico">
            <i class="bi bi-pencil-square"></i>
            <span>Planos e treinos personalizados</span>
        </div>

        <div class="topico">
            <i class="bi bi-bar-chart-line"></i>
            <span>Evolução baseada em dados reais</span>
        </div>
    </div>
</section>

<section id="sobre">
    <div class="sobre-img">
        <img src="~/img/imgSobre.png" alt="Imagem de atleta" />
    </div>

    <div class="sobre-conteudo">
        <h3>SOBRE</h3>
        <h2>Eleve seus Treinos</h2>
        <p>Monitore sua dieta e acompanhe seus treinos de forma prática e organizada, contando com o suporte e a orientação dos seus treinadores em cada etapa da sua evolução. Tenha acesso a um acompanhamento mais eficiente, registre seu desempenho diário, acompanhe metas, resultados e mantenha sua rotina alinhada para alcançar seus objetivos com mais foco, disciplina e motivação.</p>
    </div>
</section>

<section id="conteudo">
    <h3>DESTAQUES</h3>
    <h2>Conteúdos que impulsionam sua evolução</h2>
    <div class="conteudo-container">
        <div class="conteudo-card">
            <div class="conteudo-img">
                <img src="~/img/mockup.jpg" alt="Imagem de atleta" />
            </div>
            <hr class="conteudo-blur">
            <div class="conteudo-texto">
                <h3>TREINAMENTO</h3>
                <h2>Vantagens e desvantagens dos treinos por aplicativos</h2>
                <p>O treinamento físico on-line através de aplicativos oferece uma praticidade que permite aos usuários treinarem sem sair de casa, otimizando o tempo que era perdido com deslocamentos que agora podem ser aproveitados com outras tarefas pessoais.</p>
                <a href="https://ge.globo.com/eu-atleta/treinos/noticia/vantagens-e-desvantagens-dos-treinos-por-aplicativos.ghtml" target="_blank"><i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="conteudo-card">
            <div class="conteudo-img">
                <img src="~/img/comida_2.jpg" alt="Imagem de atleta" />
            </div>
            <hr class="conteudo-blur">
            <div class="conteudo-texto">
                <h3>NUTRICIONAL</h3>
                <h2>Entenda a importância de ter uma alimentação saudável</h2>
                <p>A alimentação saudável é fundamental para evitar o aparecimento de doenças, como o diabetes, hipertensão, problemas do coração e AVC. Além disso, os bons hábitos alimentares garantem uma ingestão adequada de nutrientes.</p>
                <a href="https://g1.globo.com/sc/santa-catarina/especial-publicitario/hospital-sao-jose/noticia/2022/06/30/entenda-a-importancia-de-ter-uma-alimentacao-saudavel.ghtml" target="_blank"><i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="conteudo-card">
            <div class="conteudo-img">
                <img src="~/img/box.jpg" alt="Imagem de atleta" />
            </div>
            <hr class="conteudo-blur">
            <div class="conteudo-texto">
                <h3>ATIVIDADES</h3>
                <h2>Os Benefícios de Manter Prática de Atividades Físicas na Rotina</h2>
                <p>Nos últimos anos a obesidade vem ganhando proporções alarmantes no Brasil, o número de obesos e pessoas com sobrepeso quase dobrou e no atual cenário em que se vive com o fechamento temporário das academias e estúdios.</p>
                <a href="https://laboro.edu.br/blog/os-beneficios-da-pratica-de-atividade-fisica-orientada-via-aplicativo/" target="_blank"><i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

<section id="objetivo">
    <div class="objetivo-conteudo">
        <h3>FOCO - PLANO - DISCIPLINA</h3>
        <h2>Defina e Alcance seus objetivos</h2>
        <p>Tenha clareza de onde está, onde quer chegar e o plano certo para evoluir.</p>
    </div>

    <div class="objetivo-topicos">
        <div class="objetivo-card">
            <i class="bi bi-activity"></i>
            <span><b>Avalie seu nivel</b> e desempenho</span>
        </div>
        <div class="objetivo-card">
            <i class="bi bi-graph-up-arrow"></i>
            <span><b>Defina metas</b> reais e mensuráveis</span>
        </div>
        <div class="objetivo-card">
            <i class="bi bi-eye"></i>
            <span><b>Acompanhe</b> sua evolução</span>
        </div>
        <div class="objetivo-card">
            <i class="bi bi-battery-full"></i>
            <span><b>Ajuste e evolua</b> continuamente</span>
        </div>
    </div>
</section>

<section id="ferramenta">
    <h3>FERRAMENTAS</h3>
    <h2>Dados que guiam, resultados que aparecem.</h2>
    <div class="ferramenta-container">
        <div class="ferramenta-card">

        </div>
        <div class="ferramenta-card">

        </div>
        <div class="ferramenta-card">

        </div>
        <div class="ferramenta-card">

        </div>
    </div>
</section>

<section id="motivacao">
    <h2>Evolua com estratégia <br> e acompanhamento</h2>
</section>

<section id="beneficio">
    <div class="beneficio-card" style="background-image:url('@Url.Content("~/img/imgBeneficio.png")')">>
        <div class="card-conteudo">
            <p>Crie metas personalizadas para sua evolução física e esportiva.</p>
        </div>
    </div>
    <div class="beneficio-card" style="background-image:url('@Url.Content("~/img/bike.jpg")')">>
        <div class="card-conteudo">
            <p>Visualize métricas, desempenho e progresso em tempo real.</p>
        </div>
    </div>
    <div class="beneficio-card" style="background-image:url('@Url.Content("~/img/tenis.jpg")')">>
        <div class="card-conteudo">
            <p>Seu treinador acompanha sua rotina e ajusta seus treinos quando necessário.</p>
        </div>
    </div>
    <div class="beneficio-card" style="background-image:url('@Url.Content("~/img/focus.jpg")')">>
        <div class="card-conteudo">
            <p>Tenha acesso a treinos personalizados focados no seu objetivo.</p>
        </div>
    </div>
</section>

<section id="acesso">
    <h3>ACESSE SUA ÁREA</h3>
    <h2>Tudo que você precisa, no seu nível.</h2>
    <div class="acesso-container">

        <div class="acesso-card verde">
            <div class="acesso-card-header">
                <span class="acesso-tag">Atleta</span>
                <h3 id='acesso-title'>Sua evolução, com disciplina.</h3>
                <p class="acesso-frase">"Cada treino marcado é uma prova de que você não desistiu."</p>
            </div>
            <ul class="acesso-lista">
                <li><span class="icone">🏋️</span> Treinos montados pelo seu treinador</li>
                <li><span class="icone">✅</span> Marque o que você concluiu</li>
                <li><span class="icone">🎯</span> Metas da semana sempre visíveis</li>
                <li><span class="icone">📊</span> Seu peso e massa muscular atualizados</li>
                <li><span class="icone">🔥</span> Frequência semanal calculada automaticamente</li>
            </ul>
        </div>

        <div class="acesso-card cinza">
            <div class="acesso-card-header">
                <span class="acesso-tag">Treinador</span>
                <h3 id='acesso-title'>Gerencie sua equipe com inteligência.</h3>
                <p class="acesso-frase">"Um bom treinador não apenas cria treinos — ele transforma pessoas."</p>
            </div>
            <ul class="acesso-lista">
                <li><span class="icone">📨</span> Convide e monte sua equipe</li>
                <li><span class="icone">📝</span> Crie, edite e organize treinos</li>
                <li><span class="icone">🎯</span> Defina metas semanais por atleta</li>
                <li><span class="icone">📈</span> Veja engajamento, peso e massa de cada atleta</li>
                <li><span class="icone">🗑️</span> Gerencie quem está na sua equipe</li>
            </ul>
        </div>

    </div>
</section>